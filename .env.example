# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Gemini API Key (PRIMARY - used for AI interview + admin score calculation)
# Get your FREE API key at: https://aistudio.google.com/apikey
# Uses model: gemini-2.0-flash
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Anthropic Claude API Key (OPTIONAL - used as primary if provided, Gemini is fallback)
# Get your API key at: https://console.anthropic.com/
# Uses model: claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs API Key (OPTIONAL - for Text-to-Speech) - Server side only
# Get your API key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
